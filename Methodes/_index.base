filters:
  or:
    - type == "methode"
    - couche.contains("methode")
views:
  - type: table
    name: Toutes les méthodes
    order:
      - file.name
      - domaine
      - thèmes
      - file.mtime
      - skill_version
    sort:
      - property: file.name
        direction: ASC
    columnSize:
      file.name: 280
  - type: table
    name: Récents
    order:
      - file.name
      - domaine
      - file.mtime
    sort:
      - property: file.mtime
        direction: DESC
